@using KonciergeUi.Client.Components.Layout.Modals

@using KonciergeUI.Core.Abstractions
@using KonciergeUI.Models.Kube
@using KonciergeUi.Client.Extensions
@using KonciergeUI.Translations.Services
@inject IClusterDiscoveryService ClusterService
@inject ILocalizationService L
@inject IDialogService DialogService

<MudStack StretchItems="StretchItems.Start" Row>
    <MudTooltip Text="@L.Resources["no_clusters_found"]" Disabled="@(!NoClusters)">
        <MudButton Color="Color.Primary"
                   Style="justify-content: flex-start; width: 100%"
                   FullWidth="true"
                   OnClick="OpenContextDialog"
                   Variant="Variant.Outlined"
                   Disabled="@(Disabled || IsLoading || NoClusters)">
            <MudStack AlignItems="AlignItems.Center" Row>
                @if (IsLoading)
                {
                    <MudProgressCircular Indeterminate="true" Size="Size.Small" Color="Color.Primary" />
                }
                else
                {
                    <MudIcon Color="Color.Primary" Icon="@KonciergeIcons.Outlined.Resources" />
                }
                <MudStack AlignItems="AlignItems.Start">
                    @if (IsLoading)
                    {
                        <MudText Style="font-weight:bold" Typo="Typo.subtitle2">@Label</MudText>
                        <MudText Style="font-style:italic" Typo="Typo.body2">@L.Resources["loading_cluster"]</MudText>
                    }
                    else if (SelectedCluster is null)
                    {
                        <MudText Style="font-weight:bold" Typo="Typo.subtitle2">@Label</MudText>
                        <MudText Style="font-style:italic" Typo="Typo.body2">@L.Resources["select_cluster"]</MudText>
                    }
                    else
                    {
                        <MudText Style="font-weight:bold" Typo="Typo.subtitle2">
                            @($"{SelectedCluster.Name}@{SelectedCluster.ClusterUrl.ToClusterHost()}")
                        </MudText>
                        <MudText Style="font-style:italic" Typo="Typo.body2">
                            @($"{GetGroupLabel(SelectedCluster.KubeconfigPath)} {@L.Resources["default_namespace"]}: {SelectedCluster.DefaultNamespace}")
                        </MudText>
                    }
                </MudStack>
            </MudStack>
        </MudButton>
    </MudTooltip>
</MudStack>

@code {
    private Dictionary<string, List<ClusterConnectionInfo>> _groupedClusters = new();
    private bool IsLoading = true;

    [Parameter]
    public ClusterConnectionInfo? SelectedCluster { get; set; }

    [Parameter]
    public EventCallback<ClusterConnectionInfo?> _onClusterSelection { get; set; }

    [Parameter]
    public string Label { get; set; } = "Select cluster";

    [Parameter]
    public Variant Variant { get; set; } = Variant.Outlined;

    [Parameter]
    public bool Disabled { get; set; }

    private bool NoClusters => !IsLoading && !_groupedClusters.Any();


    protected override async Task OnInitializedAsync()
    {
        await LoadClusters();
    }
    


    private async Task LoadClusters()
    {
        IsLoading = true;
        StateHasChanged();

        try
        {
            var data = await ClusterService.DiscoverClustersAsync();

            // Group by kubeconfig path
            _groupedClusters = data
                .GroupBy(c => c.KubeconfigPath)
                .OrderByDescending(g => g.Any(c => c.IsDefaultKubeconfig)) // Default first
                .ThenBy(g => g.Key)
                .ToDictionary(
                    g => g.Key, 
                    g => g.OrderByDescending(c => c.IsCurrentContext)
                          .ThenBy(c => c.Name)
                          .ToList()
                );
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Failed to load clusters: {ex.Message}");
            _groupedClusters = new();
        }
        finally
        {
            IsLoading = false;
            StateHasChanged();
        }
    }

    private string GetGroupLabel(string kubeconfigPath)
    {
        if (kubeconfigPath.Contains("~/.kube/config") || kubeconfigPath.Contains("\\.kube\\config") )
            return "Default kubeconfig (~/.kube/config)";

        return kubeconfigPath.ToFileNameIfPath();
    }

    public async Task RefreshAsync()
    {
        await LoadClusters();
    }

    public async Task ClusterSelected(ClusterConnectionInfo? sel)
    {
        await _onClusterSelection.InvokeAsync(sel);
    }

    private async Task OpenContextDialog()
    {
        var parameters = new DialogParameters<ContextSelectDialog>
        {
            { x => x._groupedClusters, _groupedClusters },
            { x => x.SelectedContext, SelectedCluster }
        };

        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Medium };
        var dialog = await DialogService.ShowAsync<ContextSelectDialog>(null, parameters, options);
        var result = await dialog.Result;

        if (result is { Canceled: true })
        {
            return;
        }

        if (result!.Data is ClusterConnectionInfo selected)
        {
            SelectedCluster = selected;
            await ClusterSelected(selected);
        }
    }
}
