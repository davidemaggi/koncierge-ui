@using KonciergeUi.Client.Components.Layout.Summaries
@using KonciergeUI.Core.Abstractions
@using KonciergeUI.Models.Forwarding
@using KonciergeUI.Models.Kube
@using KonciergeUI.Models.Security
@using static KonciergeUI.Models.Forwarding.Enums
@using System.Linq
@using KonciergeUI.Translations.Services
@inject IKubeRepository KubeRepo
@inject ILocalizationService L
<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.DeviceHub" Class="mr-3 mb-n1"/>
            @L.Forwards["create_forward_title"]
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudStack>
            <ResourceSummary Kind="Kind" Namespace="@Namespace"  ResourceName="@ResourceName"/>
        <MudForm  @bind-IsValid="@_success" @bind-Errors="@_errors">
            <MudStack>
                <MudStack Row>
                    <MudNumericField Disabled="true" @bind-Value="_newForwardRequest.TargetPort" Label="@L.Forwards["remote_port"]" Variant="Variant.Text" Min="0" Max="65535"/>
                    <MudNumericField @bind-Value="_newForwardRequest.LocalPort" Label="@L.Forwards["local_port"]" Variant="Variant.Text" Min="0" Max="65535"/>
                </MudStack>
                <MudSelect T="ForwardProtocol"
                           Label="@L.Forwards["protocol"]"
                           Variant="Variant.Outlined"
                           @bind-Value="_newForwardRequest.Protocol"
                           Disabled="true"
                           >
                    <MudSelectItem  Value="ForwardProtocol.Http">HTTP</MudSelectItem>
                    <MudSelectItem  Value="ForwardProtocol.Https">HTTPS</MudSelectItem>
                    <MudSelectItem  Value="ForwardProtocol.Tcp">TCP</MudSelectItem>
                    <MudSelectItem  Value="ForwardProtocol.Grpc">GRPC</MudSelectItem>
                </MudSelect>
            </MudStack>
        </MudForm>
            <MudStack StretchItems="StretchItems.Start" Row>
                <MudText>@L.Forwards["linked_secrets"]</MudText>
                <MudSpacer/>
                <MudChip T="string" OnClick="ShowAddLinked">@L.Forwards["link_a_secret"]</MudChip>
            </MudStack>
            @if (SelectedLinks.Count > 0)
            {
                <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1">
                    @foreach (var link in GetOrderedSelectedLinks())
                    {
                        <MudChip T="string"
                                 Variant="Variant.Outlined"
                                 Color="Color.Info"
                                 Icon="@GetSecretSourceIcon(link.SourceType)"
                                 OnClose="@(() => RemoveSelectedLink(link))"
                                 CloseIcon="@Icons.Material.Filled.Close">
                            @BuildSecretChipLabel(link)
                        </MudChip>
                    }
                </MudStack>
            }
            @if (ConfigMapsSel.Count != 0 || SecretsSel.Count != 0){
            <MudCard Outlined="true">
                    <MudList T="SecretReference" @bind-SelectedValues="SelectedLinks" SelectionMode="SelectionMode.MultiSelection" ReadOnly="false" CheckBoxColor="Color.Tertiary">
                        <MudListSubheader>
                            @L.Forwards["select_item_link"]:
                        </MudListSubheader>

                        @if (ConfigMapsSel.Count>0){
                        <MudListItem Text="@L.Global["k8s_configmaps"]">
                            <NestedList>
                                @foreach(var cm in ConfigMapsSel)
                                {
                                    <MudListItem Text="@cm.Key">
                                        <NestedList>
                                            
                                                    @foreach(var d in cm.Value)
                                                    {

                                                        <MudListItem T="SecretReference" Value="d" Text="@($"{d.Key}")" />

                                                    }

                                            
                                        </NestedList>
                                    </MudListItem>

                                }
                            </NestedList>
                        </MudListItem>
                        }
                        @if (SecretsSel.Count > 0)
                        {
                            <MudListItem Text="@L.Global["k8s_secrets"]">
                                <NestedList>
                                    @foreach(var s in SecretsSel)
                                    {
                                        <MudListItem Text="@s.Key">
                                            <NestedList>
                                            
                                                @foreach(var d in s.Value)
                                                {

                                                    <MudListItem T="SecretReference" Value="d" Text="@($"{d.Key}")" />

                                                }

                                            
                                            </NestedList>
                                        </MudListItem>

                                    }
                                </NestedList>
                            </MudListItem>
                        }
                    </MudList>
             </MudCard>
            }
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">@L.Global["crud_cancel"]</MudButton>
        <MudButton Color="Color.Success" OnClick="CreateForward">@L.Global["crud_create"]</MudButton>
    </DialogActions>
</MudDialog>
@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter]
    public ContainerPort? ContainerPort { get; set; } 

    [Parameter]
    public ResourceType Kind { get; set; }
    [Parameter]
    public string Namespace { get; set; } = null!;

    [Parameter]
    public string ResourceName { get; set; } = null!;

    [Parameter]
    public ServicePort? ServicePort { get; set; } 

    [Parameter]
    public ClusterConnectionInfo Cluster { get; set; } = null!;

    [Parameter]
    public PortForwardDefinition? ExistingForward { get; set; }

    private void Cancel() => MudDialog.Cancel();

    private PortForwardDefinition _newForwardRequest = null!;


    private bool _success;
    private string[] _errors = [];
    private List<ConfigMapInfo> ConfigMaps { get; set; } = new List<ConfigMapInfo>();
    private List<SecretInfo> Secrets { get; set; } = new List<SecretInfo>();

    private Dictionary<string,List<SecretReference>> ConfigMapsSel { get; set; } = new ();
    private Dictionary<string,List<SecretReference>> SecretsSel { get; set; } = new();
    public IReadOnlyCollection<SecretReference> SelectedLinks { get; set; } = new List<SecretReference>();




    protected override async Task OnInitializedAsync()
    {
        if (ExistingForward is not null)
        {
            _newForwardRequest = CloneForward(ExistingForward);
            SelectedLinks = _newForwardRequest.LinkedSecrets.ToList();
            await LoadLinkableSecretsAsync();
            await base.OnInitializedAsync();
            return;
        }

        _newForwardRequest = new PortForwardDefinition
        {
            ResourceName = ResourceName,
            Namespace = Namespace,
            ResourceType = Kind,
            TargetPort = ContainerPort?.Port ?? ServicePort!.Port,
            LocalPort = 0,
            LinkedSecrets = new List<SecretReference>(),
            Name = $"{Namespace}.{ResourceName}:xxx",
            Id = Guid.CreateVersion7()
        };

        await base.OnInitializedAsync();
    }

    private async Task ShowAddLinked()
    {
        await LoadLinkableSecretsAsync();
    }

    private async Task LoadLinkableSecretsAsync()
    {
        ConfigMaps = await KubeRepo.ListConfigMapsAsync(Cluster, Namespace);
        Secrets = await KubeRepo.ListSecretsAsync(Cluster, Namespace);

        ConfigMapsSel = new();
        SecretsSel = new();


        foreach (var cm in ConfigMaps)
        {
            var tmp=new List<SecretReference>();
            foreach (var d in cm.Data)
            {


                tmp.Add(new SecretReference { Key=d.Key, SourceType= SecretSourceType.ConfigMap, ResourceName= cm.Name, Namespace=cm.NameSpace });

            }
            ConfigMapsSel.Add(cm.Name, tmp);

        }

        foreach (var s in Secrets)
        {
        var tmp=new List<SecretReference>();

            foreach (var d in s.Data)
            {


                tmp.Add(new SecretReference { Key = d.Key, SourceType = SecretSourceType.Secret, ResourceName = s.Name, Namespace = s.NameSpace });

            }
        SecretsSel.Add(s.Name, tmp);


        }

                RebindSelectedLinksToAvailableItems();

            }

            private void RebindSelectedLinksToAvailableItems()
            {
                if (SelectedLinks.Count == 0)
                {
                    return;
                }

                var selectedKeys = SelectedLinks
                    .Select(BuildSecretReferenceKey)
                    .ToHashSet(StringComparer.OrdinalIgnoreCase);

                var availableItems = ConfigMapsSel.Values
                    .SelectMany(x => x)
                    .Concat(SecretsSel.Values.SelectMany(x => x));

                SelectedLinks = availableItems
                    .Where(x => selectedKeys.Contains(BuildSecretReferenceKey(x)))
                    .Distinct(SecretReferenceKeyComparer.Instance)
                    .ToList();

    }



    private Task CreateForward()
    {
        try
        {
            _newForwardRequest.LinkedSecrets = SelectedLinks
                .Distinct(SecretReferenceKeyComparer.Instance)
                .ToList();
            MudDialog.Close(DialogResult.Ok(_newForwardRequest));
            return Task.CompletedTask;
        }
        catch (Exception exception)
        {
            return Task.FromException(exception);
        }
    }

    private static PortForwardDefinition CloneForward(PortForwardDefinition forward)
    {
        return forward with
        {
            LinkedSecrets = new List<SecretReference>(forward.LinkedSecrets)
        };
    }

    private static string BuildSecretReferenceKey(SecretReference reference)
    {
        return string.Join("|",
            reference.SourceType,
            reference.Namespace?.Trim() ?? string.Empty,
            reference.ResourceName.Trim(),
            reference.Key.Trim());
    }

    private IEnumerable<SecretReference> GetOrderedSelectedLinks()
    {
        return SelectedLinks
            .Distinct(SecretReferenceKeyComparer.Instance)
            .OrderBy(x => x.SourceType)
            .ThenBy(x => x.ResourceName, StringComparer.OrdinalIgnoreCase)
            .ThenBy(x => x.Key, StringComparer.OrdinalIgnoreCase);
    }

    private void RemoveSelectedLink(SecretReference link)
    {
        var toRemoveKey = BuildSecretReferenceKey(link);
        SelectedLinks = SelectedLinks
            .Where(x => !string.Equals(BuildSecretReferenceKey(x), toRemoveKey, StringComparison.OrdinalIgnoreCase))
            .ToList();
    }

    private static string BuildSecretChipLabel(SecretReference reference)
    {
        return $"{reference.ResourceName}.{reference.Key}";
    }

    private static string GetSecretSourceIcon(SecretSourceType sourceType)
    {
        return sourceType switch
        {
            SecretSourceType.ConfigMap => Icons.Material.Filled.Description,
            SecretSourceType.Secret => Icons.Material.Filled.Key,
            _ => Icons.Material.Filled.Link
        };
    }

    private sealed class SecretReferenceKeyComparer : IEqualityComparer<SecretReference>
    {
        public static SecretReferenceKeyComparer Instance { get; } = new();

        public bool Equals(SecretReference? x, SecretReference? y)
        {
            if (ReferenceEquals(x, y))
            {
                return true;
            }

            if (x is null || y is null)
            {
                return false;
            }

            return string.Equals(BuildSecretReferenceKey(x), BuildSecretReferenceKey(y), StringComparison.OrdinalIgnoreCase);
        }

        public int GetHashCode(SecretReference obj)
        {
            return StringComparer.OrdinalIgnoreCase.GetHashCode(BuildSecretReferenceKey(obj));
        }
    }

}