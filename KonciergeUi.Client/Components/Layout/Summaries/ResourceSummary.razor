@using KonciergeUI.Models.Forwarding
@using KonciergeUI.Translations.Services
@inject ILocalizationService L
<MudCard  Outlined="true">
    <MudStack>
        <MudText Style="font-family: monospace;" Typo="Typo.body2" >@L.Resources["resource"]</MudText>

        <MudStack AlignItems="AlignItems.Center"  Row>
            @if (Kind == Enums.ResourceType.Pod){
                <MudIcon Icon="@KonciergeIcons.Outlined.Pod" Size="Size.Small" Color="Color.Primary" />
            }
            else
            {
                <MudIcon Icon="@KonciergeIcons.Outlined.Service" Size="Size.Small" Color="Color.Primary" />

            }
            <MudText Style="font-family: monospace;" Typo="Typo.body1">@ResourceName</MudText>
        </MudStack>
        <MudText Style="font-family: monospace;" Typo="Typo.body2">@Namespace</MudText>

    </MudStack>
</MudCard>
@code {
    
    [Parameter]
    public Enums.ResourceType Kind { get; set; }
    [Parameter]
    public required string Namespace { get; set; } 
    [Parameter]
    public required string ResourceName { get; set; } 
    
}