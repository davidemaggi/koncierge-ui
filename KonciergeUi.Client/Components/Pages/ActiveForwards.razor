@page "/activeforwards"
@using KonciergeUi.Client.Components.Layout.Summaries
@using KonciergeUi.Client.Components.Layout.Views
@using KonciergeUI.Core.Abstractions
@using KonciergeUI.Models.Forwarding
@using KonciergeUI.Translations.Services
@using KonciergeUi.Client.Extensions
@inject IPortForwardingService ForwardService;
@inject ILocalizationService L
@inject IDialogService DialogService

<MudStack Class="ma-4">
    @if (Templates.Any())
    {
        <MudCard>
            <MudCardContent>
                <MudStack>
                    <MudGrid>
                        @foreach (var template in Templates)
                        {
                            <MudItem xs="12">
                                <RunningTemplateSummary Template="template" OnTemplateStopped="HandleTemplateStopped" />
                            </MudItem>
                        }
                    </MudGrid>
                    <MudButton OnClick="StopAll" Color="Color.Error" Variant="Variant.Filled" >@L.Forwards["cmd_stop_all"]</MudButton>
                </MudStack>
            </MudCardContent>
            @*
            <MudCardActions>
                <MudButton OnClick="StartForward"  StartIcon="@Icons.Material.Filled.PlayArrow" Color="Color.Success">Start Forward</MudButton>
                <MudButton  StartIcon="@Icons.Material.Filled.Save" Color="Color.Primary">Create Template</MudButton>

            </MudCardActions>
            *@
        </MudCard>
    }
    else
    {
        <NoEntry  _icon="@KonciergeIcons.Outlined.ActiveForwards" _title="No active forwards"  _subtitle="Start a template from the Templates tab to see active port forwards here" />
    }
</MudStack>


@code {

    private List<RunningTemplate> Templates { get; set; } = new();

    protected override Task OnInitializedAsync()
    {
        try
        {
            Templates =  ForwardService.GetAllRunningTemplates()
                .OrderBy(x => x.Sorting)
                .ToList();
            return Task.CompletedTask;
        }
        catch (Exception exception)
        {
            return Task.FromException(exception);
        }
    }

    private void HandleTemplateStopped(Guid templateId)
    {
        Templates.RemoveAll(t => t.TemplateId == templateId);
        StateHasChanged();
    }

    private async Task StopAll()
    {
        if (Templates.Count == 0)
        {
            return;
        }

        await DialogService.ShowConfirmationActionAsync(async () =>
        {
            var toStop = Templates.Select(t => t.TemplateId).Distinct().ToList();
            foreach (var templateId in toStop)
            {
                await ForwardService.StopTemplateAsync(templateId);
            }

            Templates.Clear();
            
            await InvokeAsync(StateHasChanged);
        });
    }

}
